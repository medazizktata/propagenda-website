NEXT_PUBLIC_SITE_URL=https://thepropagenda.com
NEXT_PUBLIC_GA_ID=

# --- Feature flags (Vercel → Project → Environment Variables) ---
# true/false, 1/0, on/off all work.

# Soft launch: lock unfinished pages behind coming-soon popup. Default on.
NEXT_PUBLIC_FF_SOFT_LAUNCH=true

# Unlock individual routes while soft launch stays on (default locked):
NEXT_PUBLIC_FF_PAGE_ABOUT=false
NEXT_PUBLIC_FF_PAGE_SERVICES=false
NEXT_PUBLIC_FF_PAGE_WORK=false
NEXT_PUBLIC_FF_PAGE_BLOG=false
NEXT_PUBLIC_FF_PAGE_CONTACT=false
NEXT_PUBLIC_FF_PAGE_LEGAL=false

# Orange quote splash on every full page load. Default on.
NEXT_PUBLIC_FF_INIT_LOADER=true

CONTACT_FORM_ENDPOINT=
CONTACT_FORM_API_KEY=
RESEND_API_KEY=
